{
  "version": 2,
  "regions": ["bom1"],
  "functions": {
    "src/server.js": {
      "runtime": "@vercel/node@22.x"
    }
  },
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ]
}