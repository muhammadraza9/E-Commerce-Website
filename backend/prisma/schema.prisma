generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
}

model order {
  id             Int             @id @default(autoincrement())
  trackingId     String          @unique
  customer       String
  email          String
  phone           String
  address        String
  subtotal       Float           @default(0)
  discountAmount Float           @default(0)
  couponCode     String?
  shippingFee    Float           @default(0)
  taxAmount      Float           @default(0)
  taxPercentage  Float           @default(0)
  grandTotal     Float           @default(0)
  total          Float
  status         String          @default("Pending")
  createdAt      DateTime        @default(now())
  paymentMethod  String          @default("COD")
  paymentStatus  String          @default("PENDING")
  txnRefNo       String?
  userId         Int?

  user           user?           @relation(fields: [userId], references: [id])
  items          orderitem[]
  returnRequest  returnrequest?

  @@index([userId], map: "order_userId_fkey")
}

model orderitem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float

  order     order   @relation(fields: [orderId], references: [id], map: "OrderItem_orderId_fkey")
  product   product @relation(fields: [productId], references: [id], map: "OrderItem_productId_fkey")

  @@index([orderId], map: "OrderItem_orderId_fkey")
  @@index([productId], map: "OrderItem_productId_fkey")
}

model product {
  id          Int         @id @default(autoincrement())
  name        String
  description String
  image       String      @db.LongText
  category    String      @default("Clothing")
  price       Float
  featured    Boolean     @default(false)
  stock       Int         @default(0)
  createdAt   DateTime    @default(now())

  orderitem   orderitem[]
  reviews     review[]
}

model user {
  id                   Int       @id @default(autoincrement())
  username             String
  email                String    @unique
  password             String
  role                 String    @default("USER")
  profileImage         String?   @db.LongText
  profileImagePublicId String?
  resetOtp             String?
  resetOtpExpiry       DateTime?
  createdAt            DateTime  @default(now())

  orders               order[]
  reviews              review[]
}

model review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String   @db.Text
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model adminsetting {
  id                  Int      @id @default(1)
  storeName           String   @default("Style Avenue")
  storeEmail          String   @default("support@styleavenue.pk")
  phoneNumber         String   @default("+92 312 6779452")
  currency            String   @default("PKR")
  shippingFee         Float    @default(500)
  freeShippingLimit   Float    @default(50000)
  storeAddress        String   @db.Text
  storeLogoUrl        String?  @db.LongText
  whatsappNumber      String?
  instagramUrl        String?  @db.LongText
  facebookUrl         String?  @db.LongText
  supportHours        String   @default("Monday - Saturday: 10:00 AM - 9:00 PM")
  taxPercentage       Float    @default(0)
  codEnabled          Boolean  @default(true)
  freeShippingEnabled Boolean  @default(true)
  orderPrefix         String   @default("SA")
  lowStockAlertLimit  Int      @default(5)
  maintenanceMode     Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model coupon {
  id           Int       @id @default(autoincrement())
  code         String    @unique
  type         String
  value        Float
  minimumOrder Float     @default(0)
  expiryDate   DateTime?
  usageLimit   Int       @default(0)
  usedCount    Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model returnrequest {
  id            Int      @id @default(autoincrement())
  orderId       Int      @unique
  customer      String
  email         String
  reason        String
  message       String?  @db.Text
  status        String   @default("Pending")
  stockRestored Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order         order    @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "ReturnRequest_orderId_fkey")

  @@index([email])
}

model activitylog {
  id         Int      @id @default(autoincrement())
  adminId    Int?
  adminEmail String?
  action     String
  entity     String
  entityId   String?
  message    String    @db.Text
  createdAt  DateTime  @default(now())

  @@index([adminId])
  @@index([entity])
  @@index([createdAt])
}