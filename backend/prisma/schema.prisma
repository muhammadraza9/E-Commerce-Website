generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
}

model order {
  id            Int         @id @default(autoincrement())
  trackingId    String      @unique
  customer      String
  email         String
  phone         String
  address       String
  total         Float
  status        String      @default("Pending")
  createdAt     DateTime    @default(now())
  paymentMethod String      @default("COD")
  paymentStatus String      @default("PENDING")
  txnRefNo      String?
  userId        Int?
  user          user?       @relation(fields: [userId], references: [id])
  items         orderitem[]

  @@index([userId], map: "order_userId_fkey")
}

model orderitem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float

  order     order   @relation(fields: [orderId], references: [id], map: "OrderItem_orderId_fkey")
  product   product @relation(fields: [productId], references: [id], map: "OrderItem_productId_fkey")

  @@index([orderId], map: "OrderItem_orderId_fkey")
  @@index([productId], map: "OrderItem_productId_fkey")
}

model product {
  id          Int         @id @default(autoincrement())
  name        String
  description String
  image       String      @db.LongText
  category    String      @default("Clothing")
  price       Float
  featured    Boolean     @default(false)
  createdAt   DateTime    @default(now())

  orderitem   orderitem[]
  reviews     review[]
}

model user {
  id        Int      @id @default(autoincrement())
  username  String
  email     String   @unique
  password  String
  role      String   @default("USER")
  createdAt DateTime @default(now())

  orders    order[]
  reviews   review[]
}

model review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String  @db.Text
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model adminsetting {
  id                Int      @id @default(1)
  storeName         String   @default("Style Avenue")
  storeEmail        String   @default("support@styleavenue.pk")
  phoneNumber       String   @default("+92 312 6779452")
  currency          String   @default("PKR")
  shippingFee       Float    @default(500)
  freeShippingLimit Float    @default(50000)
  storeAddress      String   @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}